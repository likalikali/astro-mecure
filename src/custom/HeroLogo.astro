<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1114 470" fill="#fff" id="logo-root"
  filter="url(#logo-filter)" class="h-24 md:h-28 drop-shadow-[0px_2px_3px_rgb(31,41,55,.5)]">
  <defs>
    <filter id="logo-filter">
      <feTurbulence type="fractalNoise" baseFrequency="0 0" numOctaves="1" result="warp" seed="1">
        <animate attributeName="baseFrequency" dur="4000ms" begin="1s"
          values="0 0; 0.02 0.5; 0 0; 0 0; 0.002 0.4; 0 0; 0 0" keyTimes="0; 0.05; 0.05; 0.1; 0.1; 0.15; 1"
          repeatCount="indefinite"></animate>
      </feTurbulence>
      <feDisplacementMap xChannelSelector="R" yChannelSelector="G" scale="30" in="SourceGraphic" in2="warp">
      </feDisplacementMap>
      <feDropShadow dx="0" dy="0" stdDeviation="0" flood-color="#ff0024" flood-opacity="0">
        <animate attributeName="dx" dur="4000ms" begin="1s" values="0; -4; 0; 0; -4; 0; 0"
          keyTimes="0; 0.05; 0.05; 0.1; 0.1; 0.15; 1" repeatCount="indefinite"></animate>
        <animate attributeName="flood-opacity" dur="4000ms" begin="1s" values="0; 1; 0; 0; 1; 0; 0"
          keyTimes="0; 0.05; 0.05; 0.1; 0.1; 0.15; 1" repeatCount="indefinite"></animate>
      </feDropShadow>
      <feDropShadow dx="0" dy="0" stdDeviation="0" flood-color="#00feff" flood-opacity="0">
        <animate attributeName="dx" dur="4000ms" begin="1s" values="0; 4; 0; 0; 4; 0; 0"
          keyTimes="0; 0.05; 0.05; 0.1; 0.1; 0.15; 1" repeatCount="indefinite"></animate>
        <animate attributeName="flood-opacity" dur="4000ms" begin="1s" values="0; 1; 0; 0; 1; 0; 0"
          keyTimes="0; 0.05; 0.05; 0.1; 0.1; 0.15; 1" repeatCount="indefinite"></animate>
      </feDropShadow>
      <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="rgb(0,0,0)" flood-opacity="0.2"></feDropShadow>
    </filter>
  </defs>

  <g id="logo" opacity="0">
    <rect id="triggerbox" width="1114" height="470" fill="rgba(0,0,0,0)"></rect>
    <text id="anriri-logo" x="557" y="250" text-anchor="middle" dominant-baseline="middle"
      font-family="Georgia, 'Times New Roman', serif" font-size="162" font-weight="700" letter-spacing="9">Anriri</text>
  </g>

  <style>
    #logo {
      animation: logo__to 3000ms forwards cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    #anriri-logo {
      animation: logoSlideDown 3000ms forwards cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    @keyframes logo__to {
      0% {
        opacity: 0
      }

      16% {
        opacity: 0
      }

      33% {
        opacity: 1
      }

      100% {
        opacity: 1
      }
    }

    @keyframes logoSlideDown {
      0% {
        transform: translateY(-50%)
      }

      16% {
        transform: translateY(-50%)
      }

      33% {
        transform: translateY(0)
      }

      100% {
        transform: translateY(0)
      }
    }
  </style>
</svg>
